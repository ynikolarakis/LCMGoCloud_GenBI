# GenBI Backend — Environment Variables
# Copy to .env for local development

GENBI_ENVIRONMENT=development
GENBI_LOG_LEVEL=DEBUG

# Metadata database (local dev — use full connection string)
GENBI_METADATA_DB_URL=host=localhost port=5432 dbname=genbi user=genbi password=genbi

# AWS region
GENBI_AWS_REGION=eu-west-1

# LLM
GENBI_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
GENBI_BEDROCK_MAX_TOKENS=4096

# Auth (disabled by default)
# GENBI_AUTH_ENABLED=true
# GENBI_COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
# GENBI_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Query limits
GENBI_QUERY_TIMEOUT_SECONDS=30
GENBI_QUERY_MAX_ROWS=10000

# Rate limiting
GENBI_RATE_LIMIT_RPM=60
